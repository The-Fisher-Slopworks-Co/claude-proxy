# OAuth token from `claude setup-token` (subscription auth).
# If unset, the proxy falls back to the Claude Code CLI's stored login.
# ANTHROPIC_API_KEY is deliberately ignored and never passed to Claude Code.
CLAUDE_CODE_OAUTH_TOKEN=

# Client API key. REQUIRED — the proxy refuses to start without it.
# Clients send it as `Authorization: Bearer <API_KEY>` (OpenAI-standard).
# Generate a project-tagged key, e.g.  echo "sk-cproxy-$(openssl rand -hex 32)"
API_KEY=

# Bind address. 127.0.0.1 keeps the proxy local; only expose a wider
# interface now that API_KEY gates every /v1/* request.
HOST=127.0.0.1
PORT=8787

# Model used when the request omits "model" or asks for a gpt-* model.
# Aliases (sonnet|opus|haiku) or full IDs (claude-sonnet-5, claude-opus-4-8, ...).
DEFAULT_MODEL=sonnet

# Comma-separated Claude Code tool names to enable (e.g. "WebSearch,WebFetch").
# Empty (default) = all built-in tools disabled — plain ask/answer behavior.
ALLOWED_TOOLS=

# info (default) — one line per request lifecycle event.
# debug — adds full prompts/responses, SDK message flow, and subprocess stderr.
LOG_LEVEL=info

# pretty — human-readable "HH:MM:SS LEVEL event key=value" lines.
# json — JSON lines for collectors.
# Default: pretty on a terminal, json when piped.
LOG_FORMAT=
